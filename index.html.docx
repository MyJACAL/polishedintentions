<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Polished Intentions by Alicia</title>

<style>
body {
    margin: 0;
    font-family: 'Arial', sans-serif;
    background-color: #000;
    color: #fff;
    text-align: center;
}

h1, h2 {
    color: #D4AF37;
}

.hero {
    padding: 80px 20px;
}

.tagline {
    font-size: 28px;
    margin: 20px 0;
}

.subtext {
    color: #ccc;
    margin-bottom: 30px;
}

.button {
    background-color: #0B6B53;
    color: #D4AF37;
    padding: 15px 30px;
    text-decoration: none;
    border-radius: 30px;
    font-weight: bold;
}

.section {
    padding: 60px 20px;
}

.services {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
}

.card {
    border: 1px solid #D4AF37;
    padding: 20px;
    width: 250px;
}

.gallery img {
    width: 200px;
    border-radius: 10px;
    margin: 10px;
}

.footer {
    padding: 40px;
    font-size: 14px;
    color: #aaa;
}
</style>

</head>

<body>

<!-- HERO -->
<div class="hero">
    <h1>Polished Intentions by Alicia</h1>
    <div class="tagline">Luxe Intentions. Flawless Nails.</div>
    <div class="subtext">Designed with intention. Finished to perfection.</div>

    <a href="#booking" class="button">BOOK YOUR APPOINTMENT</a>
</div>

<!-- SERVICES -->
<div class="section">
    <h2>Services</h2>

    <div class="services">
        <div class="card">
            <h3>Full Set Acrylic</h3>
            <p>Starting at $XX</p>
        </div>

        <div class="card">
            <h3>Acrylic Fill</h3>
            <p>Starting at $XX</p>
        </div>

        <div class="card">
            <h3>Gel Manicure</h3>
            <p>Starting at $XX</p>
        </div>
    </div>

    <p style="margin-top:20px; color:#aaa;">
        Prices include booking & processing fee.
    </p>
</div>

<!-- GALLERY -->
<div class="section gallery">
    <h2>Recent Work</h2>

    <!-- Replace with your photos -->
    <img src="https://via.placeholder.com/200">
    <img src="https://via.placeholder.com/200">
    <img src="https://via.placeholder.com/200">
</div>

<!-- BOOKING -->
<div class="section" id="booking">
    <h2>Book Your Appointment</h2>

    <!-- Calendly Embed -->
    <div style="min-width:320px;height:700px;">
        <iframe src="https://calendly.com/YOUR-LINK"
        width="100%" height="100%" frameborder="0"></iframe>
    </div>
</div>

<!-- ABOUT -->
<div class="section">
    <h2>Meet Alicia</h2>

    <p style="max-width:600px; margin:auto;">
        I specialize in luxury nail services designed to enhance your confidence and style.
        Every set is created with intention, precision, and attention to detail.
    </p>
</div>

<!-- FOOTER -->
<div class="footer">
    Polished Intentions by Alicia • Walla Walla, Washington
</div>

</body>
</html>
